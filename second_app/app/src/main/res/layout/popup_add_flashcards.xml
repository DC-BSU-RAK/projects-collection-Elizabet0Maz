<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".popup_add_flashcards">

    <ImageView
        android:id="@+id/popupBgAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/qanda" />

    <EditText
        android:id="@+id/addQuestion"
        android:layout_width="296dp"
        android:layout_height="51dp"
        android:layout_marginStart="50dp"
        android:layout_marginTop="110dp"
        android:layout_marginEnd="25dp"
        android:layout_marginBottom="182dp"
        android:ems="10"
        android:fontFamily="@font/merienda_one"
        android:hint="Your Question"
        android:inputType="text"
        android:textColor="#F8F8F8"
        app:layout_constraintBottom_toBottomOf="@+id/popupBgAdd"
        app:layout_constraintEnd_toEndOf="@+id/popupBgAdd"
        app:layout_constraintStart_toStartOf="@+id/popupBgAdd"
        app:layout_constraintTop_toTopOf="@+id/popupBgAdd" />

    <EditText
        android:id="@+id/addAnswer"
        android:layout_width="296dp"
        android:layout_height="51dp"
        android:layout_marginStart="50dp"
        android:layout_marginTop="182dp"
        android:layout_marginEnd="25dp"
        android:layout_marginBottom="110dp"
        android:ems="10"
        android:fontFamily="@font/merienda_one"
        android:hint="Your Answer"
        android:inputType="text"
        android:textColor="#F8F8F8"
        app:layout_constraintBottom_toBottomOf="@+id/popupBgAdd"
        app:layout_constraintEnd_toEndOf="@+id/popupBgAdd"
        app:layout_constraintStart_toStartOf="@+id/popupBgAdd"
        app:layout_constraintTop_toTopOf="@+id/popupBgAdd" />

    <ImageView
        android:id="@+id/saveAddCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="95dp"
        android:layout_marginTop="254dp"
        android:layout_marginEnd="95dp"
        android:layout_marginBottom="37dp"
        app:layout_constraintBottom_toBottomOf="@+id/popupBgAdd"
        app:layout_constraintEnd_toEndOf="@+id/popupBgAdd"
        app:layout_constraintStart_toStartOf="@+id/popupBgAdd"
        app:layout_constraintTop_toTopOf="@+id/popupBgAdd"
        app:srcCompat="@drawable/savebtn" />
</androidx.constraintlayout.widget.ConstraintLayout>