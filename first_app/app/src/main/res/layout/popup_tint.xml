<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".popup_tint">

    <ImageView
        android:id="@+id/tray"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@+id/textView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/textView"
        app:layout_constraintVertical_bias="0.29"
        app:srcCompat="@drawable/tray" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.174" />

    <ImageView
        android:id="@+id/green"
        android:layout_width="91dp"
        android:layout_height="118dp"
        android:layout_marginStart="33dp"
        android:layout_marginTop="107dp"
        android:layout_marginEnd="287dp"
        android:layout_marginBottom="170dp"
        app:layout_constraintBottom_toBottomOf="@+id/tray"
        app:layout_constraintEnd_toEndOf="@+id/tray"
        app:layout_constraintStart_toStartOf="@+id/tray"
        app:layout_constraintTop_toTopOf="@+id/tray"
        app:srcCompat="@drawable/green" />

    <ImageView
        android:id="@+id/blue"
        android:layout_width="91dp"
        android:layout_height="118dp"
        android:layout_marginStart="99dp"
        android:layout_marginTop="194dp"
        android:layout_marginEnd="221dp"
        android:layout_marginBottom="83dp"
        app:layout_constraintBottom_toBottomOf="@+id/tray"
        app:layout_constraintEnd_toEndOf="@+id/tray"
        app:layout_constraintStart_toStartOf="@+id/tray"
        app:layout_constraintTop_toTopOf="@+id/tray"
        app:srcCompat="@drawable/blue" />

    <ImageView
        android:id="@+id/yellow"
        android:layout_width="91dp"
        android:layout_height="118dp"
        android:layout_marginStart="160dp"
        android:layout_marginTop="107dp"
        android:layout_marginEnd="160dp"
        android:layout_marginBottom="170dp"
        app:layout_constraintBottom_toBottomOf="@+id/tray"
        app:layout_constraintEnd_toEndOf="@+id/tray"
        app:layout_constraintStart_toStartOf="@+id/tray"
        app:layout_constraintTop_toTopOf="@+id/tray"
        app:srcCompat="@drawable/yellow" />

    <ImageView
        android:id="@+id/red"
        android:layout_width="91dp"
        android:layout_height="118dp"
        android:layout_marginStart="221dp"
        android:layout_marginTop="201dp"
        android:layout_marginEnd="99dp"
        android:layout_marginBottom="76dp"
        app:layout_constraintBottom_toBottomOf="@+id/tray"
        app:layout_constraintEnd_toEndOf="@+id/tray"
        app:layout_constraintStart_toStartOf="@+id/tray"
        app:layout_constraintTop_toTopOf="@+id/tray"
        app:srcCompat="@drawable/red" />

    <ImageView
        android:id="@+id/white"
        android:layout_width="91dp"
        android:layout_height="118dp"
        android:layout_marginStart="292dp"
        android:layout_marginTop="120dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="157dp"
        app:layout_constraintBottom_toBottomOf="@+id/tray"
        app:layout_constraintEnd_toEndOf="@+id/tray"
        app:layout_constraintStart_toStartOf="@+id/tray"
        app:layout_constraintTop_toTopOf="@+id/tray"
        app:srcCompat="@drawable/white" />

    <ImageView
        android:id="@+id/closeButtonTint"
        android:layout_width="78dp"
        android:layout_height="70dp"
        android:layout_marginTop="37dp"
        android:layout_marginBottom="288dp"
        app:layout_constraintBottom_toBottomOf="@+id/tray"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tray"
        app:layout_constraintVertical_bias="0.0"
        app:srcCompat="@drawable/exit" />

    <TextView
        android:id="@+id/textTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="88dp"
        android:layout_marginTop="53dp"
        android:layout_marginEnd="43dp"
        android:layout_marginBottom="227dp"
        android:fontFamily="@font/beth_ellen"
        android:text="Select Tint"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="@+id/tray"
        app:layout_constraintEnd_toEndOf="@+id/tray"
        app:layout_constraintHorizontal_bias="0.314"
        app:layout_constraintStart_toStartOf="@+id/tray"
        app:layout_constraintTop_toTopOf="@+id/tray"
        app:layout_constraintVertical_bias="0.0" />

</androidx.constraintlayout.widget.ConstraintLayout>

