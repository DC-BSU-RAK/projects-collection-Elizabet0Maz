<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".popup_contrast">

    <ImageView
        android:id="@+id/tray"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@+id/textView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/textView"
        app:layout_constraintVertical_bias="0.29"
        app:srcCompat="@drawable/tray" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.174" />

    <ImageView
        android:id="@+id/lowContrast"
        android:layout_width="91dp"
        android:layout_height="118dp"
        android:layout_marginStart="31dp"
        android:layout_marginTop="184dp"
        android:layout_marginEnd="261dp"
        android:layout_marginBottom="93dp"
        app:layout_constraintBottom_toBottomOf="@+id/tray"
        app:layout_constraintEnd_toEndOf="@+id/tray"
        app:layout_constraintHorizontal_bias="0.096"
        app:layout_constraintStart_toStartOf="@+id/tray"
        app:layout_constraintTop_toTopOf="@+id/tray"
        app:layout_constraintVertical_bias="1.0"
        app:srcCompat="@drawable/low_contrast" />

    <ImageView
        android:id="@+id/midContrast"
        android:layout_width="90dp"
        android:layout_height="122dp"
        android:layout_marginStart="46dp"
        android:layout_marginTop="107dp"
        android:layout_marginEnd="199dp"
        android:layout_marginBottom="68dp"
        app:layout_constraintBottom_toBottomOf="@+id/tray"
        app:layout_constraintEnd_toEndOf="@+id/tray"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="@+id/tray"
        app:layout_constraintTop_toTopOf="@+id/tray"
        app:layout_constraintVertical_bias="0.081"
        app:srcCompat="@drawable/medium_contrast" />

    <ImageView
        android:id="@+id/highContrast"
        android:layout_width="104dp"
        android:layout_height="108dp"
        android:layout_marginStart="137dp"
        android:layout_marginTop="55dp"
        android:layout_marginEnd="102dp"
        android:layout_marginBottom="92dp"
        app:layout_constraintBottom_toBottomOf="@+id/tray"
        app:layout_constraintEnd_toEndOf="@+id/tray"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="@+id/tray"
        app:layout_constraintTop_toTopOf="@+id/tray"
        app:layout_constraintVertical_bias="0.992"
        app:srcCompat="@drawable/high_contrast" />

    <ImageView
        android:id="@+id/noContrast"
        android:layout_width="99dp"
        android:layout_height="122dp"
        android:layout_marginStart="312dp"
        android:layout_marginTop="115dp"
        android:layout_marginBottom="55dp"
        app:layout_constraintBottom_toBottomOf="@+id/tray"
        app:layout_constraintEnd_toEndOf="@+id/tray"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/tray"
        app:layout_constraintTop_toTopOf="@+id/tray"
        app:layout_constraintVertical_bias="0.0"
        app:srcCompat="@drawable/no_contrast" />

    <ImageView
        android:id="@+id/closeButtonContrast"
        android:layout_width="78dp"
        android:layout_height="70dp"
        android:layout_marginTop="37dp"
        android:layout_marginBottom="288dp"
        app:layout_constraintBottom_toBottomOf="@+id/tray"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tray"
        app:layout_constraintVertical_bias="0.0"
        app:srcCompat="@drawable/exit" />

    <TextView
        android:id="@+id/textTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="88dp"
        android:layout_marginTop="53dp"
        android:layout_marginEnd="43dp"
        android:layout_marginBottom="227dp"
        android:fontFamily="@font/beth_ellen"
        android:text="Select Contrast"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="@+id/tray"
        app:layout_constraintEnd_toEndOf="@+id/tray"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/tray"
        app:layout_constraintTop_toTopOf="@+id/tray"
        app:layout_constraintVertical_bias="0.0" />

</androidx.constraintlayout.widget.ConstraintLayout>